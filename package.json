{
  "name": "equipo-daneri-plataforma",
  "version": "1.2.1",
  "description": "Plataforma de Análisis — Equipo Daneri",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:vite": "vite",
    "build": "vite build",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder",
    "release": "node scripts/release.js",
    "preview": "vite preview",
    "test": "vitest run",
    "audit": "node C:\\Users\\mauri\\.gemini\\antigravity\\brain\\fcfa68e9-6147-4461-aaeb-4b3687f5a00f\\scratch\\search_all.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "dexie": "^4.0.7",
    "dexie-react-hooks": "^1.1.7",
    "electron-updater": "^6.2.1",
    "express": "^5.2.1",
    "fabric": "^5.5.2",
    "firebase": "^12.13.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "vite": "^5.3.1",
    "vitest": "^4.1.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.equipodaneri.plataforma",
    "productName": "Plataforma de Análisis — Equipo Daneri",
    "artifactName": "equipo-daneri-plataforma-setup-${version}.${ext}",
    "directories": {
      "output": "E:\\INSTALADORES",
      "buildResources": "public"
    },
    "publish": {
      "provider": "github",
      "owner": "MauricioDaneri",
      "repo": "equipo-daneri-plataforma"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Equipo Daneri"
    },
    "win": {
      "target": "nsis",
      "icon": "public/assets/icon.ico"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ]
  }
}
